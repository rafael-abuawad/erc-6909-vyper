# @dev We import and implement the `IERC165` interface,
# which is a built-in interface of the Vyper compiler.
from ethereum.ercs import IERC165
implements: IERC165


# @dev The `_caller` initiates a transfer of `_value` of token `_id` from `_from` to `_to`.
#      MUST be logged when an amount of a token id is transferred from one account to another.
#      MUST be logged with `_from` as the zero address when an amount of a token id is minted.
#      MUST be logged with `_to` as the zero address when an amount of a token id is burned.
event Transfer:
    _caller: address
    _from: indexed(address)
    _to: indexed(address)
    _id: indexed(uint256)
    _value: uint256


# @dev The `_owner` has set the `_approved` status for `_operator`.
#      MUST be logged when the operator status is set.
#      MAY be logged when the operator status is set to the same value as before the call.
event OperatorSet:
    _owner: indexed(address)
    _operator: indexed(address)
    _approved: bool


# @dev The `_owner` has approved `_spender` to transfer `_value` of token `_id` on the owner's behalf.
#      MUST be logged when the allowance is set by `_owner`.
event Approval:
    _owner: indexed(address)
    _spender: indexed(address)
    _id: indexed(uint256)
    _value: uint256


@external
@view
def supportsInterface(interfaceId: bytes4) -> bool:
    """
    @dev Returns `True` if this contract implements the
         interface defined by `interfaceId`.
    @notice ERC-6909 requires ERC-165; compliant contracts also
